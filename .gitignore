# Logs
*.log
logs/

# Coverage
coverage.out
coverage.html

# Pipeline output data (generated at runtime)
examples/data/raw/
examples/data/staging/
tmp/

# Ad-hoc proof / debug artifacts (one-shot proofs, captured pod logs, etc.)
tests/proofs/

# Local-mode pipeline-api state dir (default ./local-data; absolute paths
# obviously not covered).
/local-data/

# E2E scratch warehouses created under tests/e2e/testdata/
tests/e2e/testdata/e2e-*/

# Dev-only docs (RFCs, plans, spikes, audit notes, samples). Kept locally
# for project history; never pushed to the public repo.
docs/tmp/

# Helm chart dependency tarballs — Chart.lock is source of truth, run
# `helm dependency build charts/<name>` to repopulate after clone.
charts/*/charts/

